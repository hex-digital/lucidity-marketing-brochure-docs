  "devDependencies": {
    "@pkg/common": "workspace:*",
    "@pkg/errors": "workspace:*",
    "@pkg/eslint-plugin": "workspace:*",
    "@tailwindcss/postcss": "catalog:frontend",
    "@types/hast": "catalog:types",
    "@types/mdx": "catalog:types",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@vitejs/plugin-react": "catalog:bundling",
    "eslint": "catalog:lint",
    "eslint-config-next": "catalog:lint",
    "eslint-config-prettier": "catalog:lint",
