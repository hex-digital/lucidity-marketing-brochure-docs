{
  "name": "apps-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && pnpm prettier",
    "lint:fix": "eslint --fix . && pnpm prettier:fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
