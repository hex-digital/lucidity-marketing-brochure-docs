    "@pkg/next-config": "workspace:*",
    "@pkg/notifications": "workspace:*",
    "@pkg/observability": "workspace:*",
    "@radix-ui/react-presence": "catalog:ai-chat",
    "@sentry/nextjs": "catalog:observability",
    "@t3-oss/env-nextjs": "catalog:dev",
    "@takumi-rs/image-response": "catalog:utility",
    "@vercel/speed-insights": "catalog:observability",
    "ai": "catalog:ai-chat",
    "class-variance-authority": "catalog:utility",
    "flexsearch": "catalog:docs",
    "fumadocs-core": "catalog:docs",
    "fumadocs-mdx": "catalog:docs",
    "fumadocs-ui": "catalog:docs",
    "hast-util-to-jsx-runtime": "catalog:docs",
    "lucide-react": "catalog:docs",
    "motion": "catalog:frontend",
    "next": "catalog:frontend",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
