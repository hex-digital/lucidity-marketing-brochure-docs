{
  "name": "@pkg/tooling",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "type": "commonjs",
  "main": "./src/index.js",
  "author": {
    "name": "Jamie Warburton",
    "url": "https://github.com/jamiewarb"
  },
  "scripts": {
    "lint": "eslint . && pnpm prettier",
    "lint:fix": "eslint --fix . && pnpm prettier:fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "typecheck": "tsc --project ./tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "prettier": "catalog:lint"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pkg/eslint-plugin": "workspace:*",
    "@types/node": "catalog:types",
    "@vitest/coverage-v8": "catalog:testing",
    "@vitest/ui": "catalog:testing",
    "eslint": "catalog:lint",
    "postcss": "catalog:lint",
    "prettier": "catalog:lint",
    "typescript": "catalog:dev",
    "vitest": "catalog:testing"
  }
}
