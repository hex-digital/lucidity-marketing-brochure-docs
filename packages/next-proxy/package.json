{
  "name": "@pkg/next-proxy",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "lint": "eslint . && pnpm prettier",
    "lint:fix": "eslint --fix . && pnpm prettier:fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "test": "pnpm test:unit",
    "test:unit": "echo 'No tests yet. When tests added, change script to `vitest run`'",
    "typecheck": "tsc --project ./tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "next": "catalog:frontend"
  },
  "devDependencies": {
    "@pkg/eslint-plugin": "workspace:*",
    "@types/node": "catalog:types",
    "@vitest/coverage-v8": "catalog:testing",
    "eslint": "catalog:lint",
    "next": "catalog:frontend",
    "prettier": "catalog:lint",
    "typescript-plugin-css-modules": "catalog:types",
    "vitest": "catalog:testing"
  }
}
